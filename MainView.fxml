<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefHeight="400.0" prefWidth="600.0" spacing="10.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Main">
    <children>
        <Label text="Medical Office Management" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>
        <HBox spacing="15.0" VBox.vgrow="ALWAYS">
            <children>
                <VBox spacing="5.0">
                    <children>
                        <Label text="Select Patient:" />
                        <ListView fx:id="patientListView" prefWidth="200.0" />
                    </children>
                </VBox>
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label text="Patient Appointments:" />
                        <TableView fx:id="appointmentTable" prefHeight="200.0" prefWidth="200.0">
                            <columns>
                                <TableColumn prefWidth="75.0" text="Date" />
                                <TableColumn prefWidth="100.0" text="Physician" />
                                <TableColumn prefWidth="150.0" text="Notes" />
                            </columns>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </HBox>
        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <children>
                <Button text="Add New Patient" />
                <Button text="Add Appointment" />
            </children>
        </HBox>
    </children>
</VBox>
